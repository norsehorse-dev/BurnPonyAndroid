<?xml version="1.0" encoding="utf-8"?>
<!-- Standard-flavor manifest overlay: FCM service + notification permission.
     The foss flavor has neither (no Google bits in its dependency graph;
     receipts arrive via polling). -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application>
        <service
            android:name=".push.BurnPonyFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>
